<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawer_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- Status bar spacer (filled in code) -->
    <View
        android:id="@+id/status_spacer"
        android:layout_width="match_parent"
        android:layout_height="0dp" />

    <!-- Search bar -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <EditText
            android:id="@+id/et_search"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_search"
            android:hint="@string/search_apps"
            android:imeOptions="actionSearch"
            android:inputType="textFilter"
            android:paddingHorizontal="16dp"
            android:singleLine="true"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_dim"
            android:textSize="15sp" />
    </FrameLayout>

    <!-- App count label -->
    <TextView
        android:id="@+id/tv_app_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif"
        android:paddingHorizontal="24dp"
        android:paddingBottom="4dp"
        android:textColor="@color/text_dim"
        android:textSize="11sp" />

    <!-- All apps list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_apps"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="200dp" />

</LinearLayout>
